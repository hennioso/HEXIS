# Bitunix API Credentials
# Create your API keys at: https://www.bitunix.com -> Avatar -> API Management
BITUNIX_API_KEY=your_bitunix_api_key_here
BITUNIX_SECRET_KEY=your_bitunix_secret_key_here

# Anthropic API Key (required for AI Trade Analyst)
# Get your key at: https://console.anthropic.com -> API Keys
# Cost: ~$3/month with default 4h analysis interval (claude-opus-4-6)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Dashboard Authentication (strongly recommended if accessible outside localhost)
# DASHBOARD_USER=admin
# DASHBOARD_PASSWORD=change_me_to_something_strong
# FLASK_SECRET_KEY=generate_with__python_-c__"import_secrets;print(secrets.token_hex(32))"

# Telegram Notifications (optional)
# 1. Create a bot via @BotFather → copy the token
# 2. Send a message to your bot, then open:
#    https://api.telegram.org/bot<TOKEN>/getUpdates
#    Copy the "id" from the "chat" object
# TELEGRAM_TOKEN=123456789:ABCdefGhIJKlmNoPQRsTUVwxyZ
# TELEGRAM_CHAT_ID=987654321

# Multi-AI Trade Analyst (optional — Claude is always required above)
# Adding OpenAI and/or Gemini enables multi-model consensus analysis
# OPENAI_API_KEY=sk-...         # Enables GPT-4o as second analyst
# GOOGLE_API_KEY=AIza...        # Enables Gemini as third analyst

# Circuit Breakers (optional — defaults are set in config.py)
# DAILY_LOSS_LIMIT_USDT=-30.0    # Pause ALL trading when today's PnL < this
# MAX_CONSECUTIVE_LOSSES=4       # Auto-disable a strategy after N SL hits in a row

# Trading Parameters (optional — defaults are set in config.py)
# RISK_PER_TRADE=0.05        # 5% capital risk per trade
# LEVERAGE=10                # Futures leverage (must match Bitunix setting)
# STOP_LOSS_PCT=0.025        # 2.5% stop loss (trend strategy)
# TAKE_PROFIT_PCT=0.050      # 5.0% take profit (trend strategy, 2:1 R:R)
# SCALP_STOP_LOSS_PCT=0.008  # 0.8% stop loss (scalp strategy)
# SCALP_TAKE_PROFIT_PCT=0.016 # 1.6% take profit (scalp strategy, 2:1 R:R)
# MAX_MARGIN_TRADES=10       # Learning phase: cap position size for first N trades
# MAX_MARGIN_USDT=25.0       # Learning phase: max margin per trade in USDT
# MAX_MARGIN_PCT=0.05        # Hard cap: margin never exceeds 5% of balance
