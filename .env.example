# ─────────────────────────────────────────────────────────────────────────────
# HEXIS – Environment Configuration
# Copy this file to .env and fill in your values.
# Lines starting with # are comments and are ignored.
# ─────────────────────────────────────────────────────────────────────────────

# ── Bitunix API (required) ────────────────────────────────────────────────────
# Create keys at: https://www.bitunix.com → Avatar → API Management
BITUNIX_API_KEY=your_bitunix_api_key_here
BITUNIX_SECRET_KEY=your_bitunix_secret_key_here

# ── Flask / Security (required) ───────────────────────────────────────────────
# Used for session cookies and API-key encryption — keep this secret and stable.
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=change_me_to_a_long_random_string

# ── Anthropic API (required for AI Trade Analyst) ─────────────────────────────
# Get your key at: https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Telegram Notifications (optional) ────────────────────────────────────────
# 1. Create a bot via @BotFather → copy the token
# 2. Message your bot, then visit:
#    https://api.telegram.org/bot<TOKEN>/getUpdates → copy "id" from "chat"
# TELEGRAM_TOKEN=123456789:ABCdefGhIJKlmNoPQRsTUVwxyZ
# TELEGRAM_CHAT_ID=987654321

# ── SMTP Email (optional — needed for invite code emails) ─────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASSWORD=your_app_password
# SMTP_FROM=HEXIS Bot <your@gmail.com>

# ── Stripe Payments (optional — needed for paid invite codes) ─────────────────
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_PUBLISHABLE_KEY=pk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_ID=price_...            # ID of your product price in Stripe dashboard
# HEXIS_BASE_URL=https://yourdomain.com   # Used for Stripe redirect URLs

# ── Multi-AI Trade Analyst (optional) ────────────────────────────────────────
# Adding OpenAI and/or Gemini enables multi-model consensus analysis.
# OPENAI_API_KEY=sk-...
# GOOGLE_API_KEY=AIza...

# ── Position Sizing (optional — default: 7.5%) ────────────────────────────────
# Each user can also override this individually via the dashboard slider.
# POSITION_MARGIN_PCT=0.075   # 7.5% of total equity used as margin per trade

# ── Circuit Breakers (optional) ───────────────────────────────────────────────
# DAILY_LOSS_LIMIT_USDT=-30.0     # Pause ALL trading when today's PnL < this
# MAX_CONSECUTIVE_LOSSES=4        # Auto-disable a strategy after N SL hits in a row

# ── Advanced Trading Parameters (optional) ────────────────────────────────────
# LEVERAGE=10                  # Futures leverage (must match Bitunix account setting)
# STOP_LOSS_PCT=0.025          # 2.5% SL (trend strategy)
# TAKE_PROFIT_PCT=0.050        # 5.0% TP (trend strategy, 2:1 R:R)
# SCALP_STOP_LOSS_PCT=0.008    # 0.8% SL (scalp strategy)
# SCALP_TAKE_PROFIT_PCT=0.016  # 1.6% TP (scalp strategy, 2:1 R:R)
# MAX_MARGIN_TRADES=10         # Learning phase: cap position size for first N trades
# MAX_MARGIN_USDT=25.0         # Learning phase: max margin per trade in USDT

# ── Dashboard Port (optional — default: 5000) ─────────────────────────────────
# DASHBOARD_PORT=5000
